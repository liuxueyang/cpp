#!/usr/bin/env bash

# This script compares the output of a.cpp with a__Good.cpp
# The input is generated by a__Generator.cpp

# Usage
# $ cp-helper a.cpp
#     This is the normal usage
# $ cp-helper
#     This will use the cpp file with the latest modified time as the a.cpp
# $ cp-helper a.cpp 20
#     Run 20 random test cases

flags=(-std=c++23 -Wall -D_DEBUG -I"$HOME/cpp/header")

function Usage_Exit {
  echo "Usage: ${0##*/} filename"
  exit
}

function compile_src {
  src=$1
  file_base=${src%.*}
  file_exe=${file_base}
  file_output=${file_base}.output
  file_err=${file_base}.err

  [[ -a "$src" ]] || { echo "$src" not found ; exit 1; }
  g++ "${flags[@]}" "$src" -o "$file_exe" || exit 1
  files=()
  files+=("$file_exe" "$file_output" "$file_err")
}

function guess_src {
  guess_file=$(ls -t *.cpp | head -n1)
  guess_file=${guess_file%.cpp}
  guess_file=${guess_file%__Good}
  guess_file=${guess_file%__Generator}
  guess_file=${guess_file}.cpp
}

guess_src

while getopts ':-:c:sp' VAL ; do
  case $VAL in
    c ) cnt="$OPTARG" ;;
    s ) stress=1 ;;
    p ) 
      clipboard=1 ;;
    - )
      case $OPTARG in
        count=* ) cnt="${OPTARG#*=}" ;;
        count ) 
          cnt="${!OPTIND}"
          (( OPTIND++ )) ;;
        stress ) stress=1 ;;
        clipboard ) clipboard=1 ;;
        * )
          echo "unknown long argument: $OPTARG"
          exit 1 ;;
      esac ;;
    : )
        echo "error: no arg supplied to $OPTARG option"
        exit 1 ;;
    * )
        echo "error: unknown option $OPTARG"
        echo "valid options are: -c NUM -s"
        exit 1 ;;
  esac
done

if [[ -n "$clipboard" ]] ; then
  if [[ ! -x /usr/bin/xsel ]] ; then
    echo "error: /usr/bin/xsel is required"
    exit 1
  elif [[ -n "$stress" ]] ; then
    echo "error: clipboard is not available for stress testing"
    exit 1
  fi
fi

if [[ -z "$stress" ]] ; then
  if [[ -n "$cnt" ]] ; then
    echo "error: count is only need for stress testing"
    exit 1
  fi
else
  cnt=${cnt:-100}
  if [[ -n "$clipboard" ]] ; then
    cnt=1
  fi
fi

shift $((OPTIND - 1))
cur_src=${1:-$guess_file}

declare -a files

compile_src "$cur_src"
cur_exe=${files[0]}
cur_output=${files[1]}
cur_err=${files[2]}

base_name=${cur_exe}

if [[ -n "$stress" ]] ; then
  good_src=${base_name}__Good.cpp
  compile_src "$good_src"
  good_exe=${files[0]}
  good_output=${files[1]}
  good_err=${files[2]}

  generator_src=${base_name}__Generator.cpp
  compile_src "$generator_src"
  generator_exe=${files[0]}

  for ((i=1; i<="$cnt"; i++)); do
    clear
    echo "Testing $i"
    input=input_${i}.txt
    ./"$generator_exe" > $input
    cat $input

    ./"$cur_exe" < "$input" > "$cur_output" 2>"$cur_err"
    ./"$good_exe" < "$input" > "$good_output" 2>"$good_err"
    if ! diff -Z "$cur_output" "$good_output" > /dev/null ; then
      echo Failed at test $i:
      bat "$input"
      delta -s "$cur_output" "$good_output"
      exit 1
    fi

    rm "$input" "$cur_output" "$good_output" "$cur_err" "$good_err"
    sleep 0.2
  done
  clear
  echo "Success!"

  rm "$cur_exe" "$good_exe" "$generator_exe"
else
  if [[ -n "$clipboard" ]] ; then
    # xsel -b | ./"$cur_exe"
    input=$(xsel -b)
  else
    input=$(cat "input.txt")
  fi

  echo "Input:"
  echo "$input" | cat
  echo "Output:"
  echo "$input" | ./"$cur_exe"
  rm -f ./"$cur_exe"
fi
